<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Lead Funnel</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box}

body{
  font-family:'Inter',sans-serif;
  background:linear-gradient(135deg,#0b1220,#020617);
  color:#fff;
}

.container{max-width:1100px;margin:auto;padding:20px}

/* Glass */
.glass{
  background:rgba(255,255,255,0.05);
  backdrop-filter:blur(12px);
  border:1px solid rgba(255,255,255,0.08);
  border-radius:16px;
}

/* NAV */
.nav{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:20px 0;
}
.logo img{height:42px}

.btn{
  background:linear-gradient(135deg,#22c55e,#4ade80);
  color:#000;
  padding:12px 22px;
  border-radius:10px;
  text-decoration:none;
  font-weight:600;
  transition:0.3s;
}
.btn:hover{
  transform:translateY(-2px);
  box-shadow:0 10px 25px rgba(34,197,94,0.3);
}

/* HERO */
.hero{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:50px;
  align-items:center;
  margin-top:60px;
}
.hero h1{
  font-size:44px;
  line-height:1.2;
}
.highlight{color:#4ade80}
.hero p{margin-top:20px;color:#cbd5e1}
.price{color:#4ade80;font-weight:700}
.hero img{width:100%;border-radius:16px}

/* Animation */
.fade-in{
  opacity:0;
  transform:translateY(30px);
  transition:0.8s ease;
}
.fade-in.show{
  opacity:1;
  transform:translateY(0);
}

.section{margin-top:90px}
.section h2{margin-bottom:25px}

/* Cards */
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
}
.card{padding:20px}

/* Flow */
.flow{
  text-align:center;
  line-height:2;
  color:#cbd5e1;
}

/* FORM */
.form input,.form textarea{
  width:100%;
  padding:12px;
  margin-bottom:12px;
  border-radius:8px;
  border:none;
  background:#020617;
  color:#fff;
}

/* Founder */
.founder{
  display:grid;
  grid-template-columns:150px 1fr;
  gap:20px;
  align-items:center;
}
.founder img{
  width:150px;
  border-radius:12px;
}

/* Floating WhatsApp */
.floating{
  position:fixed;
  bottom:20px;
  right:20px;
  background:#25D366;
  color:#000;
  padding:14px;
  border-radius:50%;
  font-size:18px;
  text-decoration:none;
  box-shadow:0 10px 25px rgba(0,0,0,0.3);
}

/* Footer */
.footer{
  text-align:center;
  margin-top:60px;
  color:#94a3b8;
}

/* Mobile */
@media(max-width:768px){
.hero{grid-template-columns:1fr}
.founder{grid-template-columns:1fr;text-align:center}
}
</style>
</head>

<body>

<div class="container">

<!-- NAV -->
<div class="nav">
  <div class="logo">
    <img src="/logo.png">
  </div>
  <a class="btn" href="https://wa.me/917762058535?text=Hi%20I%20am%20interested%20in%20the%20lead%20funnel">WhatsApp</a>
</div>

<!-- HERO -->
<div class="hero">
  <div class="fade-in">
    <h1>
      Stop wasting time on low-quality leads.<br>
      Get only <span class="highlight">high-intent clients.</span>
    </h1>

    <p>
      I build an AI lead funnel that filters out freebie-seekers and sends only high-intent clients to your inbox — done-for-you for <span class="price">₹14,999</span>.
    </p>

    <br>
    <a class="btn" href="https://wa.me/917762058535?text=Hi%20I%20am%20interested%20in%20the%20lead%20funnel">
      Qualify My Leads Now
    </a>

    <p style="margin-top:10px;color:#f87171">
      ⚠️ Limited: Only 5 clients per week
    </p>
  </div>

  <img class="fade-in" src="/demo.png">
</div>

<!-- MICRO PROOF -->
<div class="section fade-in">
  <h2>System Output Preview</h2>
  <div class="glass" style="padding:20px">
    <p><strong>🔥 New HOT Lead</strong></p>
    <p>Name: Raj Mehta</p>
    <p>Budget: ₹50,000+</p>
    <p>Timeline: Immediate</p>
    <p>Reason: High intent + ready to invest</p>
  </div>
</div>

<!-- TARGET -->
<div class="section fade-in">
  <h2>Built for</h2>
  <div class="grid">
    <div class="card glass">Coaches & Consultants</div>
    <div class="card glass">Immigration</div>
    <div class="card glass">Real Estate</div>
    <div class="card glass">Finance</div>
  </div>
</div>

<!-- FLOW -->
<div class="section fade-in">
  <h2>How it works</h2>
  <div class="flow glass" style="padding:20px">
    Lead submits form → AI analyzes → Scored → Hot leads sent instantly
  </div>
</div>

<!-- FILTER -->
<div class="section fade-in">
  <h2>Who this is NOT for</h2>
  <ul style="color:#cbd5e1">
    <li>❌ Looking for cheap leads</li>
    <li>❌ No clear service offering</li>
    <li>❌ Not serious about converting</li>
  </ul>
</div>

<!-- FORM -->
<div class="section fade-in">
  <h2>Get Demo</h2>
  <form class="form glass" style="padding:20px"
        action="https://formspree.io/f/mpqknjwg"
        method="POST">
    <input type="text" name="name" placeholder="Your Name" required>
    <input type="email" name="email" placeholder="Email" required>
    <input type="text" name="phone" placeholder="Phone">
    <textarea name="message" placeholder="What service do you need?"></textarea>
    <button class="btn" type="submit">Submit</button>
  </form>
</div>

<!-- PROCESS -->
<div class="section fade-in">
  <h2>What happens next</h2>
  <div class="flow glass" style="padding:20px">
    1. WhatsApp discussion<br>
    2. Funnel setup starts<br>
    3. Live in 48 hours<br>
    4. You get qualified leads
  </div>
</div>

<!-- FOUNDER -->
<div class="section fade-in">
  <h2>Founder</h2>
  <div class="founder glass" style="padding:20px">
    <img src="/founder.jpg">
    <div>
      <h3>Anuj Abhishek</h3>
      <p>AI Automation Specialist</p>
      <p>I help consultants automate lead qualification so they only talk to serious buyers.</p>
    </div>
  </div>
</div>

<!-- FINAL CTA -->
<div class="section fade-in" style="text-align:center">
  <h2>Ready to get better leads?</h2>
  <br>
  <a class="btn" href="https://wa.me/917762058535?text=Hi%20I%20am%20interested%20in%20the%20lead%20funnel">
    Chat on WhatsApp
  </a>
</div>

<div class="footer">
  Built for high-intent lead generation
</div>

</div>

<!-- Floating WhatsApp -->
<a href="https://wa.me/917762058535?text=Hi%20I%20am%20interested%20in%20the%20lead%20funnel" class="floating">💬</a>

<script>
const elements = document.querySelectorAll('.fade-in');

window.addEventListener('scroll', () => {
  elements.forEach(el => {
    const top = el.getBoundingClientRect().top;
    if(top < window.innerHeight - 50){
      el.classList.add('show');
    }
  });
});
</script>

</body>
</html>
